# Environment configuration template for Automated Web Penetration Testing System

# API Keys (MiMo API or OpenAI API)
XIAOMI_API_KEY=your_mimo_api_key_here
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# Alternatively, standard OpenAI keys if not using MiMo
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# LLM Selection
CREWAI_LLM_PROVIDER=openai
CREWAI_LLM_MODEL=mimo-v2.5-pro
